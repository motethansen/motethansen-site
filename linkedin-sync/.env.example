# Copy to .env and fill in. NEVER commit the real .env.

# ── Cloudflare (required) ─────────────────────────────
# API token needs the "Workers KV Storage : Edit" permission on this account.
CF_ACCOUNT_ID=f999794776f99de37612b4abbfbfc21a
CF_KV_NAMESPACE_ID=1b97cac1e10d4bcaaa1bef301a86af26
CF_API_TOKEN=

# ── LinkedIn (required for scraping; skip if you only use --from-file) ──
LINKEDIN_PROFILE=michaelmotethansen
# From your browser DevTools -> Application -> Cookies -> linkedin.com, while logged in.
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=

# ── Failure alerts (optional but recommended) ─────────
# Emails you when a scheduled run fails or scrapes 0 articles (expired cookie).
# Reuses the site's Resend sender. If RESEND_API_KEY/ALERT_EMAIL are unset, alerting no-ops.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@vizneo.com
ALERT_EMAIL=hansenmichaelmotet@gmail.com
